NEXT_PUBLIC_SITE_URL=https://pub.dhe.org.in
NEXT_PUBLIC_API_URL=https://vie-rase-backend.onrender.com

# Analytics (optional — enable in Vercel when ready)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXX
# NEXT_PUBLIC_GSC_VERIFICATION=your-verification-token
# NEXT_PUBLIC_CLARITY_ID=your-clarity-id
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=pub.dhe.org.in
# NEXT_PUBLIC_MATOMO_URL=https://analytics.example.com

# Monitoring (optional)
# SENTRY_DSN=https://...@sentry.io/...

# Supabase (v1.1 — enables editorial workflow + persistent metrics)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_STORAGE_BUCKET=manuscripts
# SUPABASE_SETUP_TOKEN=one-time-secret-for-post-deploy-setup

# Transactional email (Resend)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Viksit Bharat Journal <noreply@pub.dhe.org.in>

# Crossref DOI (when prefix registered)
# CROSSREF_API_KEY=...
# CROSSREF_DOI_PREFIX=10.xxxx

# ORCID OAuth
# ORCID_CLIENT_ID=...
# ORCID_CLIENT_SECRET=...

# Plagiarism screening (optional)
# PLAGIARISM_PROVIDER=turnitin
# PLAGIARISM_API_KEY=...

# Feature flag overrides (optional)
# NEXT_PUBLIC_FF_SEMANTIC_SEARCH=false
# NEXT_PUBLIC_FF_EDITORIAL_WORKFLOW=false
