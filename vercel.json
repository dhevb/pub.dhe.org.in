{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["bom1"],
  "github": {
    "enabled": true,
    "silent": true,
    "autoJobCancelation": true
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "pub.rase.co.in" }],
      "destination": "https://pub.dhe.org.in/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.pub.rase.co.in" }],
      "destination": "https://pub.dhe.org.in/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "vbe.rase.co.in" }],
      "destination": "https://pub.dhe.org.in/vbe.rase/:path*",
      "permanent": true
    },
